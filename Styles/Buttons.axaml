<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Design.PreviewWith>
        <Border Background="Black" MinWidth="500" MinHeight="400" Padding="20">
            <Grid 
                ColumnDefinitions="Auto, Auto"
                Margin="30 10">
                <!-- Left Side -->
                <StackPanel Grid.Column="0" Spacing="10" Orientation="Vertical">
                    <Button BorderThickness="2" Padding="30 0" BorderBrush="White" Classes="SideMenu-Btn">
                        <TextBlock Text="I am a navigation button!"/>
                    </Button>
                    
                    <Border 
                        Background="{DynamicResource MainMenus-Bg}"
                        Padding="20">
                        <StackPanel Orientation="Horizontal">
                            <Button Margin="10" Classes="DialogBtn GenericDialogBtn">
                                <TextBlock Text="I am a Dialog button!"/>
                            </Button>
                            <Button Margin="10" Classes="DialogBtn DangerDialogBtn">
                                <TextBlock Text="I am a Dangerous Dialog button!"/>
                            </Button>
                        </StackPanel>
                    </Border>
                    
                    <Border>
                        <StackPanel Orientation="Horizontal">
                            <Button Classes="YCTPButton Miniature">
                                <Svg Path="/Assets/UI/delete-search.svg"/>
                            </Button>
                            <Button Classes="YCTPButton">
                                <Svg Path="/Assets/UI/Inspect.svg"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Design.PreviewWith>
    
    <!-- Default Button -->
    <Style Selector="Button">
        <Setter Property="Padding" Value="0"/>
        <!-- YCTP BUTTON -->
        <Style Selector="^.YCTPButton">
            <Setter Property="Height" Value="64"/>
            <Setter Property="Width" Value="64"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#8c0d93"/>
                <Setter Property="CornerRadius" Value="15"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Padding" Value="6"/>
                <Setter Property="BoxShadow" Value="inset 2.5 -2.5 0 2 #3f043e"/>
            </Style>
            
            <!-- Icon Definitions -->
            <Style Selector="^ Svg">
                <Setter Property="Margin" Value="3 0 -0.5 2"/>
                <Setter Property="Css" Value="
                    .usesStroke { stroke: #FFFFFF; }
                    .usesFill { fill: #FFFFFF; }
                "/>
            </Style>
            
            <!-- Event Definitions -->
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="BoxShadow" Value="inset 2.5 -2.5 0 2 #bef0c0"/>
                <Setter Property="Background" Value="#75e170"/>
            </Style>
            <!-- Svg Color Update -->
            <Style Selector="^:pointerover Svg">
                <Setter Property="Css" Value="
                    .usesFill { fill: #949794; }
                    .usesStroke { stroke: #949794; }
                "/>
            </Style>
            <!-- Default Animation Disable -->
            <Setter Property="Transitions" Value="{x:Null}" />
            <Setter Property="RenderTransform" Value="none" />
            <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter"> 
                <Setter Property="RenderTransform" Value="none" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter"> 
                <Setter Property="RenderTransform" Value="none" />
            </Style>
            
            <!-- Small Version -->
            <!-- YCTP BUTTON OVERRIDE -->
            <Style Selector="^.Miniature">
                <Setter Property="Height" Value="48"/>
                <Setter Property="Width" Value="48"/>
                <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter"> 
                    <Setter Property="CornerRadius" Value="12"/>
                    <Setter Property="BoxShadow" Value="inset 2.5 -2.5 0 1 #3f043e"/>
                </Style>
                <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="BoxShadow" Value="inset 2.5 -2.5 0 1 #bef0c0"/>
                </Style>
            </Style>
        </Style>
    </Style>
    
    
    <!--SIDE MENU STYLING-->
    <Style Selector="Button.SideMenu-Btn">
        <!--=======================-->
        <!-- General Styling Below -->
        <!--=======================-->
        <Setter Property="Margin" Value="0 3" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="MinHeight" Value="55" />
        <Setter Property="MaxHeight" Value="70" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <!-- Text Styling -->
        <Style Selector="^ TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontFamily" Value="{StaticResource ComicRelief}" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <!-- Animation -->
        <Style Selector="^:pointerover TextBlock">
            <Setter Property="TextDecorations" Value="Underline"/>
        </Style>
        <!--Icon Styling-->
        <Style Selector="^ Image">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0.35" />
            <Setter Property="MinHeight" Value="64" />
            <Setter Property="MinWidth" Value="64" />
        </Style>

        <!-- Default Animation Disable -->
        <Setter Property="Transitions" Value="{x:Null}" />
        <Setter Property="RenderTransform" Value="none" />
        <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter"> 
            <Setter Property="RenderTransform" Value="none" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter"> 
            <Setter Property="RenderTransform" Value="none" />
            <Setter Property="Background" Value="Transparent" />
            <Style Selector="^ TextBlock">
                <Setter Property="TextDecorations" Value="Underline" />
            </Style>
        </Style>
    </Style>
    
    <!-- Dialog Styling -->
    <Style Selector="Button.DialogBtn">
        <Setter Property="FontFamily" Value="{StaticResource ComicRelief}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinWidth" Value="100"/>
        <Setter Property="Padding" Value="5"/>
        
        <!-- Generic One -->
        <Style Selector="^.GenericDialogBtn">
            <Setter Property="Background" Value="{DynamicResource Generic-Button}"/>
            <!-- Default Animation Disable -->
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter"> 
                <Setter Property="Background" Value="{DynamicResource Generic-Button-Pointed}"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter"> 
                <Setter Property="Background" Value="{DynamicResource Generic-Button-Pressed}"/>
            </Style>
        </Style>
        
        <!-- Danger One -->
        <Style Selector="^.DangerDialogBtn">
            <Setter Property="Background" Value="{DynamicResource Danger-Button}"/>
            <!-- Default Animation Disable -->
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter"> 
                <Setter Property="Background" Value="{DynamicResource Danger-Button-Pointed}"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter"> 
                <Setter Property="Background" Value="{DynamicResource Danger-Button-Pressed}"/>
            </Style>
        </Style>
    </Style>
</Styles>
