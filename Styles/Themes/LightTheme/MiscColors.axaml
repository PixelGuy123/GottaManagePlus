<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- MISC Colors -->
    <SolidColorBrush x:Key="TabSelectedBg" Color="#124B0E"/>
    <SolidColorBrush x:Key="ProgressBar-Foreground" Color="#8ADB84"/>

    <Color x:Key="ScrollBar-BgColor">rgba(50, 100, 65, 1)</Color>
    <Color x:Key="ScrollBar-ThumbColor">rgba(159, 220, 182, 1)</Color>
    <Color x:Key="WhiteColor">#FFFFFFFF</Color>
    <Color x:Key="BlackColor">#000000</Color>
</ResourceDictionary>