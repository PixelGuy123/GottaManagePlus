<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- BG Tiling Settings -->
    <ImageBrush x:Key="MainWindowBg"
                Source="/Assets/UI/Dark/MainWindowBG.png"
                TileMode="Tile"
                Stretch="None"
                DestinationRect="0,0,256,256" />

    <ImageBrush x:Key="SettingsBg"
                Source="/Assets/UI/Dark/SettingsBG.png"
                TileMode="Tile"
                Stretch="None"
                DestinationRect="0,0,256,256" />

    <ImageBrush x:Key="ModsListBg"
                Source="/Assets/UI/Dark/ModViewBG.png"
                TileMode="Tile"
                Stretch="None"
                DestinationRect="0,0,256,256" />
</ResourceDictionary>