<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Design.PreviewWith>
        <Border Padding="20" Background="Green">
            <TextBlock
                Name="HeaderTitle"
                Text="This is a header" />
        </Border>
    </Design.PreviewWith>
    
    <!-- Default Textblock Color -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource BlackColor}"/>
        
        <!-- Header Title Properties-->
        <Style Selector="^#HeaderTitle">
            <Setter Property="Margin" Value="68 5 0 5"/>
            <Setter Property="FontFamily" Value="{StaticResource Baskerville}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Style>
    
</Styles>
