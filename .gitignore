```gitignore
# Build artifacts
bin/
obj/
*.dll
*.exe
*.pdb
*.so
*.dylib
*.jar
*.war
*.class
*.o
*.obj
*.out

# Dependencies
packages/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs
*.log

# User-specific files
.vs/
*.user
*.userosscache
*.suo
*.csproj.user
*.userprefs

# Environment specific settings
.env
.env.local
.env.*
!.env.example

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Testing
coverage/
*.gcov
*.lcov
*.profdata
*.profraw

# IDE specific
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Distribution / packaging
dist/
build/
*.tar.gz
*.whl
*.egg-info/
```