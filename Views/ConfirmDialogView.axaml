<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:GottaManagePlus.ViewModels"
             x:DataType="vm:ConfirmDialogViewModel"
             x:Class="GottaManagePlus.Views.ConfirmDialogView"
             MinWidth="350"
             MinHeight="250">

    <Design.DataContext><vm:ConfirmDialogViewModel/></Design.DataContext>

    <UserControl.Styles>
        <StyleInclude Source="/Styles/TextBlock.axaml"/>
        <StyleInclude Source="/Styles/Buttons.axaml"/>
    </UserControl.Styles>

    <Border
        CornerRadius="10"
        Margin="10 10"
        BoxShadow="0 5 25 1.5 Black">
        <Border
            Background="{DynamicResource MainMenus-Bg}"
            CornerRadius="10"
            ClipToBounds="True">
            <Grid RowDefinitions="Auto, Auto, Auto"> <!-- Title | Description + Logs | Buttons -->
                <!-- Title -->
                <TextBlock
                    Grid.Row="0"
                    Background="{DynamicResource Menu-Header-Bg}"
                    Text="{CompiledBinding Title, Mode=OneWay}"
                    MaxWidth="650"
                    HorizontalAlignment="Stretch"
                    TextAlignment="Center"
                    Padding="10"
                    FontSize="25"
                    TextTrimming="CharacterEllipsis"
                    FontWeight="ExtraLight"
                    FontFamily="{StaticResource WorkSans}"/>

                <!-- Description -->
                <StackPanel Grid.Row="1">
                    <!-- Description Text -->
                    <TextBlock
                        Padding="10"
                        Text="{CompiledBinding Message, Mode=OneWay}"
                        MaxWidth="650"
                        TextWrapping="Wrap"
                        TextAlignment="{CompiledBinding DescriptionAlignment, Mode=OneWay}"
                        FontSize="18"
                        FontFamily="{StaticResource ComicRelief}"
                    />

                    <!-- Logs TreeDataGrid (only visible if LogContainer has logs) -->
                    <TreeDataGrid
                        MaxHeight="125"
                        Background="{DynamicResource Generic-Border}"
                        BorderBrush="{DynamicResource Generic-Border-Shadow}"
                        BorderThickness="0 2"
                        IsVisible="{CompiledBinding LogContainer.HasLogs, FallbackValue=False, Mode=OneWay}"
                        ShowColumnHeaders="False"
                        FontFamily="{StaticResource WorkSans}"
                        Source="{CompiledBinding LogsTreeSource, Mode=OneWay}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel
                    Orientation="Horizontal"
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    Spacing="20"
                    Margin="10">
                    <Button
                        IsVisible="{CompiledBinding !OnlyConfirmButton, Mode=OneWay}"
                        Content="{CompiledBinding CancelText, Mode=OneWay}"
                        Classes="DialogBtn DangerDialogBtn"
                        IsCancel="True"
                        Command="{Binding Cancel}"/>
                    <Button
                        IsDefault="True"
                        Content="{CompiledBinding ConfirmText, Mode=OneWay}"
                        Classes="DialogBtn GenericDialogBtn"
                        Command="{Binding Confirm}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
