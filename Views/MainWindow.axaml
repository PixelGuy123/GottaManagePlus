<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GottaManagePlus.ViewModels"
        xmlns:app="using:GottaManagePlus"
        xmlns:converters="using:GottaManagePlus.Styles.Converters"
        xmlns:models="using:GottaManagePlus.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:gameEnvironments="clr-namespace:GottaManagePlus.Models.GameEnvironments"
        mc:Ignorable="d" d:DesignWidth="1720" d:DesignHeight="820"
        x:Class="GottaManagePlus.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        WindowStartupLocation="CenterScreen"

        Name="Root"
        Icon="/Assets/avalonia-logo.ico"
        WindowState="Normal"
        MinHeight="700"
        MinWidth="1080"
        Title="Gotta Manage Plus">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <Design.DesignStyle>
        <StyleInclude Source="/Styles/style.axaml"/>
    </Design.DesignStyle>

    <!-- Styles to define -->
    <Window.Styles>
        <StyleInclude Source="/Styles/style.axaml"/>
        <StyleInclude Source="/Styles/HyperlinkButton.axaml"/>
        
        <!-- App Info Style -->
        <Style Selector="TextBlock.AppInfo">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="TextWrapping" Value="WrapWithOverflow"/>
            <Setter Property="FontFamily" Value="{StaticResource ComicRelief}"/>
        </Style>
        
        <!-- Menu Style -->
        <Style Selector="Menu">
            <Setter Property="FontFamily" Value="{StaticResource Baskerville}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="{DynamicResource Generic-Border}"></Setter>
        </Style>
        
        <Style Selector="MenuItem[IsEnabled=False]">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
    </Window.Styles>
    
    <!-- Resources to Include -->
    <Window.Resources>
        <ResourceDictionary>
            <converters:InsertSuffixConverter x:Key="InsertSuffixConverter"/>
            <converters:InsertPrefixConverter x:Key="InsertPrefixConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/ProfileVisualization/ProfileResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <!-- Dock Panel for Menu -->
    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem 
                Header="_Profiles">
                <MenuItem.IsEnabled>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="!#DialogBorder.IsVisible"/>
                        <Binding Path="!!ProfileMetadataCollection.Count"/>
                    </MultiBinding>
                </MenuItem.IsEnabled>
                <!-- Current Profile -->
                <MenuItem
                    IsHitTestVisible="False" 
                    Foreground="DarkGray"
                    FontSize="15"
                    FontWeight="Bold"
                    FontStyle="Italic"
                    Header="{CompiledBinding SelectedProfile.Name, FallbackValue=No Profile Selected!, Converter={StaticResource InsertPrefixConverter}, ConverterParameter=Current Profile:}">
                </MenuItem>
                <Separator/>
                
                <!-- Profile Actions -->
                <MenuItem Header="_Add..." Command="{Binding CreateProfileUi}"/>
                <MenuItem Header="_Export..." Command="{Binding ExportProfileUi}"/>
                <MenuItem Header="_Delete..." 
                          Command="{Binding DeleteProfileUi}"
                          IsHitTestVisible="{CompiledBinding ProfileMetadataCollection.Count, FallbackValue=False, Converter={x:Static converters:EqualityConverters.IsHigherThanOne}}"
                          Opacity="{CompiledBinding ProfileMetadataCollection.Count, FallbackValue=0.5, Converter={x:Static converters:EqualityConverters.IsHigherThanOne_Opacity}}"/>
                <Separator/>
                
                <!-- Switch Profile Option -->
                <MenuItem Header="Switch Profile..."
                          IsHitTestVisible="{CompiledBinding ProfileMetadataCollection.Count, FallbackValue=False, Converter={x:Static converters:EqualityConverters.IsHigherThanOne}}"
                          Opacity="{CompiledBinding ProfileMetadataCollection.Count, FallbackValue=0.5, Converter={x:Static converters:EqualityConverters.IsHigherThanOne_Opacity}}"
                          SelectedItem="{CompiledBinding SelectedProfile, Mode=OneWay}"
                          ItemsSource="{CompiledBinding ProfileMetadataCollection}">
                    <MenuItem.ItemContainerTheme>
                        <ControlTheme x:DataType="models:ProfileMetadata" TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Header" Value="{CompiledBinding Name}" />
                            <Setter Property="Command" 
                                    Value="{Binding #Root.((vm:MainWindowViewModel)DataContext).SwitchToProfileUi}" />
                            <Setter Property="CommandParameter" Value="{CompiledBinding }" />
                            <Setter Property="IsVisible">
                                <MultiBinding Converter="{x:Static converters:EqualityConverters.AtLeastOneNotEqual}">
                                    <Binding />
                                    <Binding Path="#Root.((vm:MainWindowViewModel)DataContext).SelectedProfile"/>
                                </MultiBinding>
                            </Setter>
                        </ControlTheme>
                    </MenuItem.ItemContainerTheme>
                </MenuItem>
                <MenuItem
                    IsHitTestVisible="False" 
                    Foreground="DarkGray"
                    FontFamily="{StaticResource WorkSans}"
                    FontSize="11"
                    Header="{CompiledBinding ProfileCount, Converter={StaticResource InsertSuffixConverter}, ConverterParameter=Profiles}">
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Help"
                      IsEnabled="{CompiledBinding !#DialogBorder.IsVisible}">
                <MenuItem Header="About" Command="{Binding RevealAboutSection}"/>
                <MenuItem Header="License" Command="{Binding RevealAboutSection}"/>
            </MenuItem>
        </Menu>
        <!-- START of Body -->
        <SplitView
            IsPaneOpen="{CompiledBinding SideMenuOpen, Mode=TwoWay}"
            Background="{StaticResource MainWindowBg}"
            PanePlacement="Left"
            PaneBackground="Black"
            DisplayMode="Overlay"
            OpenPaneLength="150">
            <!-- Content SplitView -->
            <SplitView.Content>
                <Panel>
                    <!-- Current Page Control -->
                    <ContentControl
                        Content="{CompiledBinding CurrentPage, Mode=OneWay}" />
                    <!-- Sidebar button -->
                    <Button
                        Command="{Binding ToggleSideMenu}"
                        IsHitTestVisible="{CompiledBinding !SideMenuOpen}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="6 1 0 0"
                        Classes="YCTPButton Miniature">
                        <Svg Path="/Assets/UI/Sidebar.svg"/>
                    </Button>
                    <!-- Dialog Element -->
                    <Border
                        Name="DialogBorder"
                        Background="#7D000000"
                        Opacity="{CompiledBinding Dialog.IsDialogOpen, FallbackValue=0, Mode=OneWay}"
                        IsVisible="{CompiledBinding !!Opacity, Mode=OneWay, RelativeSource={RelativeSource Self}}">
                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition
                                    Property="Opacity"
                                    Duration="0:0:0.1"
                                    Easing="SineEaseOut"
                                    />
                            </Transitions>
                        </Border.Transitions>
                        <ContentControl
                            IsVisible="{CompiledBinding Dialog, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Content="{CompiledBinding Dialog, Mode=OneWay}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>
                    <!-- End of Dialog Element -->
                </Panel>
            </SplitView.Content>
            
            <!-- START of Side Menu -->
            <SplitView.Pane>
                <Panel IsHitTestVisible="{CompiledBinding SideMenuOpen}">
                    <!-- YCTP Border -->
                    <Border 
                        BorderBrush="{StaticResource YctpBg}" 
                        BorderThickness="0 0 5 0" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Stretch"/>
            
                    <!-- Side Content -->
                    <ContentControl 
                        Padding="4 0 10 0"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch">
                        <Grid RowDefinitions="Auto, *">
                            <!-- Navigation Body -->
                            <StackPanel Grid.Row="0" Orientation="Vertical">
                                <!-- Close Pane Button -->
                                <Button
                                    Command="{Binding ToggleSideMenu}"
                                    HorizontalAlignment="Right"
                                    Classes="YCTPButton Miniature"
                                    Margin="0 0 -6 10">
                                    <Svg Path="/Assets/UI/exit.svg"/>
                                </Button>
                                
                                <!-- Logo -->
                                <Image
                                    Classes="GlowShadow"
                                    HorizontalAlignment="Center"
                                    Source="/Assets/UI/Logo.png"/>
                                <Separator
                                    BorderThickness="0,1,0,0"
                                    BorderBrush="White"
                                    Margin="0,10" />
                                
                                <!-- Navigation -->
                                <!-- Home -->
                                <Button
                                    IsHitTestVisible="{CompiledBinding ExecutablePathSet}"
                                    Opacity="{CompiledBinding ExecutablePathSet, Converter={x:Static converters:BoolConverters.BoolToOpacityIndicator}}"
                                    Classes="SideMenu-Btn"
                                    Command="{Binding GoToHome}">
                                    <TextBlock Text="Home"/>
                                </Button>
                                <!-- Settings -->
                                <Button
                                    Classes="SideMenu-Btn"
                                    Command="{Binding GoToSettings}">
                                    <TextBlock Text="Settings"/>
                                </Button>
                            </StackPanel>
                            
                            <!-- App Info -->
                            <StackPanel Grid.Row="1"
                                        Margin="0 5"
                                        VerticalAlignment="Bottom" 
                                        Orientation="Vertical">
                                <!-- Links -->
                                <HyperlinkButton 
                                    HorizontalAlignment="Left" 
                                    NavigateUri="{x:Static app:HyperLinks.DiscordLink}">
                                    <Image 
                                        Source="/Assets/UI/Button_DiscordCommunity_YCTP.png"
                                        Stretch="Uniform"
                                    />
                                </HyperlinkButton>
                                
                                <!-- App Author -->
                                <TextBlock
                                    Margin="0 10 0 0"
                                    Classes="AppInfo"
                                    Text="Made by: PixelGuy"/>
                                <TextBlock
                                    Classes="AppInfo"
                                    Opacity="0.75"
                                    FontSize="11">
                                    Build <Run Text="{x:Static app:AppInfo.AppVersion}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </ContentControl>
                </Panel>
            </SplitView.Pane>
            <!-- END of Side Menu -->
        </SplitView>
        <!-- END of Body -->
    </DockPanel>
</Window>