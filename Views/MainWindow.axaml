<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GottaManagePlus.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1720" d:DesignHeight="820"
        x:Class="GottaManagePlus.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        WindowStartupLocation="CenterScreen"

        Icon="/Assets/avalonia-logo.ico"
        WindowState="Normal"
        MinHeight="700"
        MinWidth="1080"
        Title="Gotta Manage Plus">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <Design.DesignStyle>
        <StyleInclude Source="/Styles/style.axaml"/>
    </Design.DesignStyle>

    <!-- Styles to define -->
    <Window.Styles>
        <StyleInclude Source="/Styles/style.axaml"/>
    </Window.Styles>
    
    <!-- Resources to Include -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/ProfileVisualization/ProfileResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- START of Body -->
    <SplitView
        IsPaneOpen="False"
        Background="{StaticResource MainWindowBg}"
        PanePlacement="Left"
        PaneBackground="Black"
        DisplayMode="Overlay"
        OpenPaneLength="150">
        <!-- Content SplitView -->
        <SplitView.Content>
            <Panel>
                <!-- Current Page Control -->
                <ContentControl
                    Content="{CompiledBinding CurrentPage, Mode=OneWay}" />
                <!-- Sidebar button -->
                <Button
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="-2.5 -3 0 0"
                    Classes="YCTPButton">
                    <Svg Path="/Assets/UI/Sidebar.svg"/>
                </Button>
                <!-- Dialog Element -->
                <Border
                    Background="#7D000000"
                    IsVisible="{CompiledBinding !!Opacity, Mode=OneWay, RelativeSource={RelativeSource Self}}"
                    Opacity="{CompiledBinding Dialog.IsDialogOpen, FallbackValue=0, Mode=OneWay}">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition
                                Property="Opacity"
                                Duration="0:0:0.1"
                                Easing="SineEaseOut"
                                />
                        </Transitions>
                    </Border.Transitions>
                    <ContentControl 
                        Content="{CompiledBinding Dialog, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <!-- End of Dialog Element -->
            </Panel>
        </SplitView.Content>
        
        <!-- START of Side Menu -->
        <SplitView.Pane>
            <Grid ClipToBounds="True">
                <!-- YCTP Border -->
                <Border 
                    BorderBrush="{StaticResource YctpBg}" 
                    BorderThickness="0 0 5 0" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Stretch"/>
        
                <!-- Side Content -->
                <ContentControl 
                    Padding="0 0 5 0"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
                    <StackPanel Orientation="Vertical">
                        <Button
                            HorizontalAlignment="Right"
                            Classes="YCTPButton"
                            Width="40" Height="40"
                            Margin="0 0 0 10">
                            <Svg Path="/Assets/UI/Sidebar.svg"/>
                        </Button>
                        <Image
                            HorizontalAlignment="Center"
                            Source="/Assets/UI/Logo.png"/>
                    </StackPanel>
                </ContentControl>
            </Grid>
        </SplitView.Pane>
        <!-- END of Side Menu -->
    </SplitView>
    <!-- END of Body -->
</Window>