<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GottaManagePlus.ViewModels"
        xmlns:app="using:GottaManagePlus"
        xmlns:converters="using:GottaManagePlus.Styles.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1720" d:DesignHeight="820"
        x:Class="GottaManagePlus.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        WindowStartupLocation="CenterScreen"

        Icon="/Assets/avalonia-logo.ico"
        WindowState="Normal"
        MinHeight="700"
        MinWidth="1080"
        Title="Gotta Manage Plus">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <Design.DesignStyle>
        <StyleInclude Source="/Styles/style.axaml"/>
    </Design.DesignStyle>

    <!-- Styles to define -->
    <Window.Styles>
        <StyleInclude Source="/Styles/style.axaml"/>
        
        <Style Selector="TextBlock.AppInfo">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="TextWrapping" Value="WrapWithOverflow"/>
            <Setter Property="FontFamily" Value="{StaticResource ComicRelief}"/>
        </Style>
    </Window.Styles>
    
    <!-- Resources to Include -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/ProfileVisualization/ProfileResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- START of Body -->
    <SplitView
        IsPaneOpen="{CompiledBinding SideMenuOpen}"
        Background="{StaticResource MainWindowBg}"
        PanePlacement="Left"
        PaneBackground="Black"
        DisplayMode="Overlay"
        OpenPaneLength="150">
        <!-- Content SplitView -->
        <SplitView.Content>
            <Panel>
                <!-- Current Page Control -->
                <ContentControl
                    Content="{CompiledBinding CurrentPage, Mode=OneWay}" />
                <!-- Sidebar button -->
                <Button
                    Command="{Binding ToggleSideMenu}"
                    IsHitTestVisible="{CompiledBinding !SideMenuOpen}"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="2 -3.75 0 0"
                    Classes="YCTPButton">
                    <Svg Path="/Assets/UI/Sidebar.svg"/>
                </Button>
                <!-- Dialog Element -->
                <Border
                    Background="#7D000000"
                    IsVisible="{CompiledBinding !!Opacity, Mode=OneWay, RelativeSource={RelativeSource Self}}"
                    Opacity="{CompiledBinding Dialog.IsDialogOpen, FallbackValue=0, Mode=OneWay}">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition
                                Property="Opacity"
                                Duration="0:0:0.1"
                                Easing="SineEaseOut"
                                />
                        </Transitions>
                    </Border.Transitions>
                    <ContentControl 
                        Content="{CompiledBinding Dialog, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>
                <!-- End of Dialog Element -->
            </Panel>
        </SplitView.Content>
        
        <!-- START of Side Menu -->
        <SplitView.Pane>
            <Panel IsHitTestVisible="{CompiledBinding SideMenuOpen}">
                <!-- YCTP Border -->
                <Border 
                    BorderBrush="{StaticResource YctpBg}" 
                    BorderThickness="0 0 5 0" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Stretch"/>
        
                <!-- Side Content -->
                <ContentControl 
                    Padding="4 0 10 0"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
                    <Grid RowDefinitions="Auto, *">
                        <!-- Navigation Body -->
                        <StackPanel Grid.Row="0" Orientation="Vertical">
                            <!-- Close Pane Button -->
                            <Button
                                Command="{Binding ToggleSideMenu}"
                                HorizontalAlignment="Right"
                                Classes="YCTPButton Miniature"
                                Margin="0 0 -6 10">
                                <Svg Path="/Assets/UI/exit.svg"/>
                            </Button>
                            
                            <!-- Logo -->
                            <Image
                                Classes="GlowShadow"
                                HorizontalAlignment="Center"
                                Source="/Assets/UI/Logo.png"/>
                            <Separator
                                BorderThickness="0,1,0,0"
                                BorderBrush="White"
                                Margin="0,10" />
                            
                            <!-- Navigation -->
                            <!-- Home -->
                            <Button 
                                Opacity="{CompiledBinding ExecutablePathSet, Converter={x:Static converters:BoolConverters.BoolToOpacityIndicator}}"
                                Classes="SideMenu-Btn"
                                Command="{Binding GoToHome}">
                                <TextBlock Text="Home"/>
                            </Button>
                            <!-- Settings -->
                            <Button
                                Classes="SideMenu-Btn"
                                Command="{Binding GoToSettings}">
                                <TextBlock Text="Settings"/>
                            </Button>
                        </StackPanel>
                        
                        <!-- App Info -->
                        <StackPanel Grid.Row="1"
                                    Margin="0 5"
                                    VerticalAlignment="Bottom" 
                                    Orientation="Vertical">
                            <!-- App Author -->
                            <TextBlock
                                Classes="AppInfo"
                                Text="Made by: PixelGuy"/>
                            <TextBlock
                                Classes="AppInfo"
                                FontStyle="Italic"
                                Opacity="0.75"
                                FontSize="11"
                                Text="{CompiledBinding ., Source={x:Static app:AppInfo.AppVersion}}"/>
                        </StackPanel>
                    </Grid>
                </ContentControl>
            </Panel>
        </SplitView.Pane>
        <!-- END of Side Menu -->
    </SplitView>
    <!-- END of Body -->
</Window>