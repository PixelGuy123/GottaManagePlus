<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:GottaManagePlus.ViewModels"
             xmlns:gottaManagePlus="clr-namespace:GottaManagePlus"
             x:DataType="vm:LicenseDialogViewModel"
             x:Class="GottaManagePlus.Views.LicenseDialogView"
             MinWidth="350">

    <Design.DataContext><vm:LicenseDialogViewModel/></Design.DataContext>

    <UserControl.Styles>
        <StyleInclude Source="/Styles/TextBlock.axaml"/>
        <StyleInclude Source="/Styles/Buttons.axaml"/>
    </UserControl.Styles>

    <Border
        CornerRadius="10"
        Margin="10 10"
        BoxShadow="0 5 25 1.5 Black">
        <Border
            Background="{DynamicResource MainMenus-Bg}"
            CornerRadius="10"
            ClipToBounds="True">
            <Grid RowDefinitions="Auto, Auto, Auto"> <!-- Title | Description + Logs | Buttons -->
                <!-- Title -->
                <TextBlock
                    Grid.Row="0"
                    Background="{DynamicResource Menu-Header-Bg}"
                    Text="{CompiledBinding Title, Mode=OneWay}"
                    MaxWidth="650"
                    HorizontalAlignment="Stretch"
                    TextAlignment="Center"
                    Padding="10"
                    FontSize="25"
                    TextTrimming="CharacterEllipsis"
                    FontWeight="ExtraLight"
                    FontFamily="{StaticResource WorkSans}"/>
                
                <!-- Description Text -->
                <TextBox Grid.Row="1"
                         AcceptsReturn="True"
                         TextWrapping="Wrap" 
                         MaxHeight="200"
                         Height="150"
                         Text="{x:Static gottaManagePlus:Constants.LicenseDialogDescription}" />

                <!-- Buttons -->
                <StackPanel
                    Orientation="Horizontal"
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    Spacing="20"
                    Margin="10">
                    <!-- TODO: Localization support here -->
                    <Button
                        Content="Open License"
                        Padding="5"
                        Classes="GenericDialogBtn"
                        Command="{Binding CancelCommand}"/>
                    <Button
                        IsDefault="True"
                        Content="Close"
                        Classes="DialogBtn GenericDialogBtn"
                        Command="{Binding ConfirmCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
