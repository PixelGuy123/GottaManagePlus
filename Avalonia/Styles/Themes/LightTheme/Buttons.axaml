<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Normal Buttons -->
    <SolidColorBrush x:Key="Generic-Button" Color="#1A7B23"/>
    <SolidColorBrush x:Key="Generic-Button-Pointed" Color="#318828"/>
    <SolidColorBrush x:Key="Generic-Button-Pressed" Color="#2B572B"/>

    <!-- Danger Buttons -->
    <SolidColorBrush x:Key="Danger-Button" Color="#B90004"/>
    <SolidColorBrush x:Key="Danger-Button-Pointed" Color="#E22E10"/>
    <SolidColorBrush x:Key="Danger-Button-Pressed" Color="#570013"/>
</ResourceDictionary>